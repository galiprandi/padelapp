# 💾 DATABASE
DATABASE_URL="postgresql://user:password@host:5432/padelred"
# Set to "true" in production (Vercel) to use Neon serverless driver
USE_NEON_DRIVER="false"

# 🔐 AUTH
AUTH_SECRET="change-me"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 🌐 APP
NEXT_PUBLIC_APP_URL="https://padelred.app"
NEXT_PUBLIC_INSTALL_ORIGIN_TRIAL_TOKEN=""

# 🔔 FIREBASE (CLIENT — públicas)
# Firebase Console → Project Settings → General → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Firebase Console → Cloud Messaging → Web Configuration
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# 🔔 FIREBASE (SERVER — privadas)
# Firebase Console → Project Settings → Service Accounts → Generate Private Key
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
